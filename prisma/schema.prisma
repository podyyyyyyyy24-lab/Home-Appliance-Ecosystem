// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id          String         @id @default(cuid())
  nameEn      String         @unique
  nameAr      String
  codePrefix  String         @unique // e.g. PRF, ACC, MKP, SKN, HAP, HWR
  image       String?        // Category cover image
  active      Boolean        @default(false)
  sortOrder   Int            @default(0)
  items       CategoryItem[]
  products    Product[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CategoryItem {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image      String   // Base64 or URL
  code       String   @unique // Auto-generated: PRF-001, ACC-002, etc.
  name       String?  // Optional item name
  price      Float?   // Optional price
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id              String           @id @default(cuid())
  title           String
  description     String
  basePrice       Float
  warranty_period String?
  image           String?
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id])
  variants        ProductVariant[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  colorName   String
  colorHex    String
  piece_count Int
  image       String?
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Province {
  id          String   @id @default(cuid())
  name        String   @unique
  shippingFee Float    @default(0)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Courier {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  password      String   @default("1234")
  custodyAmount Float    @default(0)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  customerPhone   String
  customerAddress String
  provinceId      String
  province        Province @relation(fields: [provinceId], references: [id])
  totalAmount     Float
  status          String   @default("PENDING") // PENDING, OUT_FOR_DELIVERY, DELIVERED
  courierId       String?
  courier         Courier? @relation(fields: [courierId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
